{
  "i18n-ally.localesPaths": [
    "src/locales"
  ],
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "README.md": "README*,CHANGELOG*,LICENSE,CNAME",
    ".gitignore": ".gitattributes,.git*,.versionrc",
    "*.ts": "$(capture).test.ts, $(capture).test.tsx, $(capture).spec.ts, $(capture).spec.tsx, $(capture).d.ts",
    "*.tsx": "$(capture).test.ts, $(capture).test.tsx, $(capture).spec.ts, $(capture).spec.tsx,$(capture).d.ts",
    "*.env": "$(capture).env.*",
    "pyproject.toml": "uv.lock,poetry.lock,Pipfile.lock,poetry.toml,Pipfile,pyproject.toml,setup.py,setup.cfg,requirements.txt,requirements-dev.txt,requirements-test.txt,requirements-docs.txt,requirements-build.txt,requirements-optional.txt,requirements-minimum.txt,requirements-full.txt",
    "package.json": "package-lock.json,pnpm-lock.yaml,pnpm-workspace.yaml,.gitpod.yml,.npmrc,.npmignore,.browserslistrc,.node-version,.tazerc.json",
    "eslint.config.*": ".eslintignore,.prettierignore,.stylelintignore,.commitlintrc.*,.prettierrc.*,stylelint.config.*,.lintstagedrc.mjs,cspell.json,.oxlintrc.json,.oxfmtrc.json",
    "tailwind.config.mjs": "postcss.*"
  },
  "i18n-ally.keystyle": "nested",
}